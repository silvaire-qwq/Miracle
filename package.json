    "markdown-it": "^14.1.1",
    "markdown-it-katex": "^2.0.3",
    "mermaid": "^11.14.0",
    "prettier": "3.6.2",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
